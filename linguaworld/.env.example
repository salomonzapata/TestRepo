# Supabase — get these from your Supabase project dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic Claude API — https://console.anthropic.com
# NOTE: For production, proxy this through your own server to keep the key secret.
# For development/testing, this works directly in the Expo app.
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-api-key
