{
  "expo": {
    "name": "LinguaWorld",
    "slug": "linguaworld",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0a1e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.linguaworld.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "LinguaWorld uses your microphone for pronunciation practice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0a1e"
      },
      "package": "com.linguaworld.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "LinguaWorld uses your microphone for pronunciation practice."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "linguaworld"
  }
}
